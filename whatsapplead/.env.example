# Optional. If omitted, server/src/db.js will fall back to server/.env.
MONGODB_URI=
DB_NAME=PurpleBox

# The owner used when creating new leads from WhatsApp contacts.
# Recommended: existing user email in your current system.
DEFAULT_LEAD_OWNER_EMAIL=admin@example.com

# Optional API key to protect manual sync endpoint.
WHATSAPP_LEAD_API_KEY=

PORT=5075
WHATSAPP_WEB_URL=https://web.whatsapp.com
WHATSAPP_HEADLESS=false
WHATSAPP_MAX_CHATS=5
WHATSAPP_MESSAGES_PER_CHAT=5
WHATSAPP_MAX_STORE_MESSAGES=10
WHATSAPP_SYNC_INTERVAL_MS=0
WHATSAPP_SKIP_GROUP_CHATS=true
WHATSAPP_ALLOW_SYNTHETIC_PHONE=false
# Comma-separated allowlist. When set, only these labels are saved/displayed.
# Example: Inquiry,New customer
WHATSAPP_ALLOWED_LABELS=
# true -> only chats with allowed labels are synced; false -> all chats are synced.
WHATSAPP_SYNC_ONLY_ALLOWED_LABELS=false
WHATSAPP_PROFILE_DIR=.wa-profile

# Slow down automation so it clicks more like a human.
WHATSAPP_ROW_BEFORE_CLICK_MS=450
WHATSAPP_ROW_AFTER_CLICK_MS=900
WHATSAPP_BETWEEN_ROWS_MS=800
WHATSAPP_CONTACT_PANEL_SETTLE_MS=600
